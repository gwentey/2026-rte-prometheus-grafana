{
  "title": "ECP - Détail par instance",
  "uid": "ecp-detail",
  "timezone": "browser",
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "title": "Statut $ecp_instance",
      "type": "stat",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 6,
        "h": 3
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "expr": "ecp_endpoint_connected_brokers{ecp_name=\"$ecp_instance\"}",
          "instant": true
        }
      ],
      "options": {
        "colorMode": "background",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          },
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "🔴 DOWN",
                  "color": "red",
                  "index": 0
                }
              }
            },
            {
              "type": "range",
              "options": {
                "from": 1,
                "to": 1000,
                "result": {
                  "text": "✅ UP",
                  "color": "green",
                  "index": 1
                }
              }
            }
          ]
        }
      }
    },
    {
      "id": 2,
      "title": "Heap JVM % — $ecp_instance",
      "type": "timeseries",
      "gridPos": {
        "x": 6,
        "y": 0,
        "w": 18,
        "h": 6
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "expr": "(jvm_memory_used_bytes{area=\"heap\",ecp_name=\"$ecp_instance\"} / jvm_memory_max_bytes{area=\"heap\",ecp_name=\"$ecp_instance\"}) * 100",
          "legendFormat": "Heap %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 75
              },
              {
                "color": "red",
                "value": 85
              }
            ]
          },
          "custom": {
            "thresholdsStyle": {
              "mode": "line"
            }
          }
        }
      }
    },
    {
      "id": 3,
      "title": "CPU Process Java %",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 6,
        "w": 12,
        "h": 6
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "expr": "process_cpu_usage{ecp_name=\"$ecp_instance\"} * 100",
          "legendFormat": "CPU %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100
        }
      }
    },
    {
      "id": 4,
      "title": "Threads JVM actifs",
      "type": "timeseries",
      "gridPos": {
        "x": 12,
        "y": 6,
        "w": 12,
        "h": 6
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "expr": "jvm_threads_live_threads{ecp_name=\"$ecp_instance\"}",
          "legendFormat": "Threads"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          }
        }
      }
    },
    {
      "id": 5,
      "title": "Queues messages",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 12,
        "w": 24,
        "h": 6
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "expr": "ecp_endpoint_waiting_to_deliver_messages{ecp_name=\"$ecp_instance\"}",
          "legendFormat": "En attente livraison"
        },
        {
          "expr": "ecp_endpoint_waiting_to_receive_messages{ecp_name=\"$ecp_instance\"}",
          "legendFormat": "En attente réception"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 50
              }
            ]
          },
          "custom": {
            "thresholdsStyle": {
              "mode": "line"
            }
          }
        }
      }
    }
  ],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "hide": 0,
        "label": "Datasource"
      },
      {
        "name": "ecp_instance",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "query": {
          "query": "label_values(ecp_endpoint_connected_brokers{ecp_name=~\"ECP-GRT-.*\"}, ecp_name)",
          "refId": "StandardVariableQuery"
        },
        "refresh": 2,
        "label": "ECP",
        "hide": 0,
        "sort": 1
      }
    ]
  }
}