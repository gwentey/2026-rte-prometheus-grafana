{
  "title": "ECP - Global Overview",
  "uid": "ecp-global",
  "timezone": "browser",
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "title": "Statut ECP Endpoints",
      "type": "stat",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 12,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "expr": "ecp_endpoint_connected_brokers{ecp_name=~\"ECP-GRT-.*\"}",
          "instant": true,
          "legendFormat": "{{ecp_name}}"
        }
      ],
      "options": {
        "colorMode": "background",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "displayName": "${__field.labels.ecp_name}",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          },
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "🔴 DOWN",
                  "color": "red",
                  "index": 0
                }
              }
            },
            {
              "type": "range",
              "options": {
                "from": 1,
                "to": 1000,
                "result": {
                  "text": "✅ UP",
                  "color": "green",
                  "index": 1
                }
              }
            }
          ]
        }
      }
    },
    {
      "id": 2,
      "title": "Heap JVM %",
      "type": "gauge",
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 12,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "expr": "(jvm_memory_used_bytes{area=\"heap\",ecp_name=~\"ECP-GRT-.*\"} / jvm_memory_max_bytes{area=\"heap\",ecp_name=~\"ECP-GRT-.*\"}) * 100",
          "instant": true,
          "legendFormat": "{{ecp_name}}"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "displayName": "${__field.labels.ecp_name}",
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 75
              },
              {
                "color": "red",
                "value": 85
              }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "title": "Messages en attente de livraison",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 12,
        "h": 6
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "expr": "ecp_endpoint_waiting_to_deliver_messages{ecp_name=~\"ECP-GRT-.*\"}",
          "legendFormat": "{{ecp_name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "displayName": "${__field.labels.ecp_name}",
          "color": {
            "mode": "palette-classic"
          },
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 50
              }
            ]
          },
          "custom": {
            "thresholdsStyle": {
              "mode": "line"
            }
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Brokers en erreur",
      "type": "stat",
      "gridPos": {
        "x": 12,
        "y": 4,
        "w": 12,
        "h": 6
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "expr": "ecp_broker_status",
          "instant": true,
          "legendFormat": "{{broker_name}}"
        }
      ],
      "options": {
        "colorMode": "background",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "displayName": "${__field.labels.broker_name}",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          },
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "🔴 EN ERREUR",
                  "color": "red",
                  "index": 0
                }
              }
            },
            {
              "type": "range",
              "options": {
                "from": 1,
                "to": 1,
                "result": {
                  "text": "✅ OK",
                  "color": "green",
                  "index": 1
                }
              }
            }
          ]
        }
      }
    },
    {
      "id": 5,
      "title": "Jours avant expiration certificat",
      "type": "barchart",
      "gridPos": {
        "x": 0,
        "y": 10,
        "w": 12,
        "h": 6
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "expr": "ecp_endpoint_certificate_closest_expiration{ecp_name=~\"ECP-GRT-.*\"}",
          "instant": true,
          "legendFormat": "{{ecp_name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "displayName": "${__field.labels.ecp_name}",
          "unit": "d",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "orange",
                "value": 30
              },
              {
                "color": "green",
                "value": 60
              }
            ]
          }
        }
      }
    },
    {
      "id": 6,
      "title": "Messages envoyés (increase 2min)",
      "type": "timeseries",
      "gridPos": {
        "x": 12,
        "y": 10,
        "w": 12,
        "h": 6
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "expr": "increase(ecp_endpoint_sent_messages_total{ecp_name=~\"ECP-GRT-.*\"}[2m])",
          "legendFormat": "Envoyés - {{ecp_name}}"
        },
        {
          "expr": "increase(ecp_endpoint_received_messages_total{ecp_name=~\"ECP-GRT-.*\"}[2m])",
          "legendFormat": "Reçus - {{ecp_name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          }
        }
      }
    }
  ],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "hide": 0,
        "label": "Datasource"
      }
    ]
  }
}